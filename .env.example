# Postgres
POSTGRES_USER=pizzabot
POSTGRES_PASSWORD=pizzabot_dev_pw
POSTGRES_DB=pizzabot

# Backend
DATABASE_URL=postgresql+asyncpg://pizzabot:pizzabot_dev_pw@postgres:5432/pizzabot
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# OpenAI
OPENAI_API_KEY=sk-replace-me

# Meta WhatsApp Cloud API
# Where to find each value:
#   META_ACCESS_TOKEN          Business Settings → Users → System users → pizzabot →
#                              Generate token (permissions: whatsapp_business_messaging,
#                              whatsapp_business_management, business_management). Set
#                              expiration to "Never". Treat like a password.
#   META_APP_SECRET            App Dashboard → Settings → Basic → "App secret" → Show.
#                              Used to verify the X-Hub-Signature-256 on inbound webhooks.
#   META_PHONE_NUMBER_ID       App Dashboard → WhatsApp → API Setup → "From" → ID.
#                              NOT the phone number itself — a separate numeric id.
#   META_WABA_ID               App Dashboard → WhatsApp → API Setup → WhatsApp Business
#                              Account ID. Also visible under Business Settings →
#                              Accounts → WhatsApp accounts.
#   META_DISPLAY_PHONE_NUMBER  E.164 e.g. +5517991234567. Display only — Meta echoes it
#                              from the WABA, this is the value shown in the admin panel.
#   META_VERIFY_TOKEN          You make this up — any random string. Paste the same
#                              value into Meta's "Verify token" field when configuring
#                              the webhook URL (App Dashboard → WhatsApp → Configuration).
#   META_GRAPH_VERSION         Default v22.0. Bump only when migrating to a newer
#                              Graph API version.
#
# Webhook URL to register at Meta:
#   https://<your-domain>/api/webhook/meta
# Webhook fields to subscribe: messages
META_ACCESS_TOKEN=
META_APP_SECRET=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_DISPLAY_PHONE_NUMBER=
META_VERIFY_TOKEN=
META_GRAPH_VERSION=v22.0

# Bridge (Datacaixa) — set a long random token; share with bridge/config.ini
BRIDGE_TOKEN=

# Admin phones for WhatsApp alerts (comma-separated, full numbers e.g. 5511999999999)
ADMIN_PHONES=

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
