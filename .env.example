# Postgres
POSTGRES_USER=pizzabot
POSTGRES_PASSWORD=pizzabot_dev_pw
POSTGRES_DB=pizzabot

# Backend
DATABASE_URL=postgresql+asyncpg://pizzabot:pizzabot_dev_pw@postgres:5432/pizzabot
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# OpenAI
OPENAI_API_KEY=sk-replace-me

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE_NAME=pizzabot
EVOLUTION_WEBHOOK_SECRET=

# Bridge (Datacaixa) — set a long random token; share with bridge/config.ini
BRIDGE_TOKEN=

# Admin phones for WhatsApp alerts (comma-separated, full numbers e.g. 5511999999999)
ADMIN_PHONES=

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
