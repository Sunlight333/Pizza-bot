# ============================================================================
# Pizzabot — environment template
# ============================================================================
# Copy this file to `.env` and fill in the blanks. `.env` is gitignored;
# this template stays in git as a reference. NEVER commit real secrets here.
#
# Flags used below:
#   [REQ]    required — bot won't start (or won't function) without it
#   [OPT]    optional — sensible default exists or feature is non-critical
#   [TOKEN]  Bearer credential issued by a third party — treat like a password
#   [SECRET] HMAC / signing key — leaks are as bad as a token leak
#   [ID]     non-secret identifier — fine to log, still required
#   [CHOICE] you make this up — any random string works
#
# Generating random secrets:
#   openssl rand -hex 32     →  JWT_SECRET, BRIDGE_TOKEN
#   openssl rand -hex 16     →  META_VERIFY_TOKEN
# ============================================================================


# ----------------------------------------------------------------------------
# Postgres
# ----------------------------------------------------------------------------
# [REQ] Database credentials. Used by docker-compose's postgres container
# AND read by alembic + the backend. Change the password before going to prod.
POSTGRES_USER=pizzabot
POSTGRES_PASSWORD=pizzabot_dev_pw
POSTGRES_DB=pizzabot


# ----------------------------------------------------------------------------
# Backend
# ----------------------------------------------------------------------------
# [REQ] Connection strings — defaults work for docker-compose. Only change
# if you're running Postgres/Redis outside docker.
DATABASE_URL=postgresql+asyncpg://pizzabot:pizzabot_dev_pw@postgres:5432/pizzabot
REDIS_URL=redis://redis:6379/0

# [REQ] [SECRET] Signs admin JWTs. Generate with: openssl rand -hex 32
# Rotating this invalidates every admin session — operators must log in
# again. Never reuse across environments.
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# [REQ] CORS — comma-separated allowed origins for the admin/customer UI.
# Add your prod domain when deploying: https://planaltopizzasesorvetes.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ----------------------------------------------------------------------------
# OpenAI
# ----------------------------------------------------------------------------
# [REQ] [TOKEN] sk-... from https://platform.openai.com/api-keys
# The bot's brain — every customer message goes through GPT-4o via this key.
OPENAI_API_KEY=sk-replace-me


# ============================================================================
# Meta WhatsApp Cloud API
# ============================================================================
# The bot talks to the Graph API directly; the phone-WABA binding is
# permanent at Meta so there is no pairing UI in the admin panel.
#
# Webhook URL to register at Meta:
#   https://<your-domain>/api/webhook/meta
# Field to subscribe: messages
# ============================================================================

# [REQ] [TOKEN] Permanent System User token. Used for every Graph API call.
# Where: Business Settings → Users → System users → pizzabot → Generate token
# Permissions: whatsapp_business_messaging, whatsapp_business_management,
#              business_management
# Expiration: Never (otherwise the bot stops working in 60 days)
# Treat like a password — if leaked, revoke immediately and generate a new one.
META_ACCESS_TOKEN=

# [REQ] [SECRET] App secret for HMAC verification of inbound webhooks.
# Where: App Dashboard → Settings → Basic → "App secret" → Show
# Different from META_ACCESS_TOKEN — this proves that incoming webhook
# bodies are really from Meta (not a spoofer who guessed your webhook URL).
META_APP_SECRET=

# [REQ] [ID] Numeric id of the sending phone (NOT the phone number itself).
# Where: App Dashboard → WhatsApp → API Setup → "From" → Phone number ID
# Every API URL contains this: /v22.0/{META_PHONE_NUMBER_ID}/messages
META_PHONE_NUMBER_ID=

# [REQ] [ID] WhatsApp Business Account container id.
# Where: App Dashboard → WhatsApp → API Setup → WhatsApp Business Account ID
# Used for template management; the bot still sends messages without it but
# the admin Settings → WhatsApp page will show "—" for the WABA field.
META_WABA_ID=

# [OPT] E.164 display number shown in the admin panel (e.g. +5517991234567).
# Display only — Meta echoes it back from the API on /status. Set it here
# so the panel doesn't have to wait on a Graph call to show the number.
META_DISPLAY_PHONE_NUMBER=

# [REQ] [CHOICE] Freeform string YOU pick. Used once for the webhook handshake.
# Generate with: openssl rand -hex 16
# Paste the SAME value into Meta's "Verify token" field at:
#   App Dashboard → WhatsApp → Configuration → Webhook
META_VERIFY_TOKEN=

# [OPT] Graph API version. Bump only when migrating to a newer version;
# v22.0 supports everything the bot uses today.
META_GRAPH_VERSION=v22.0

# ----------------------------------------------------------------------------
# Meta message templates
# ----------------------------------------------------------------------------
# Submit each template at WhatsApp Manager → Message Templates, then paste
# the approved name into the matching key below. Leave empty until APPROVED:
# the code falls back to freeform send_text (which only works inside the 24h
# customer-service window — fine for dev, not fine for prod OTPs / alerts).
# Full submission walkthrough: docs/whatsapp_templates.md
#
# Canonical names (the values you should end up with once Meta approves):
#   META_TEMPLATE_OTP=otp_login_code               # Step 1 — AUTHENTICATION
#   META_TEMPLATE_ADMIN_ALERT=admin_alert          # Step 2 — UTILITY
#   META_TEMPLATE_HANDOFF_CUSTOMER=handoff_customer_wait  # Step 3 — UTILITY
#   META_TEMPLATE_ORDER_STATUS=order_status_update # Step 4 — UTILITY (future)
META_TEMPLATE_OTP=
META_TEMPLATE_ADMIN_ALERT=
META_TEMPLATE_HANDOFF_CUSTOMER=
META_TEMPLATE_ORDER_STATUS=


# ============================================================================
# Integrations
# ============================================================================

# [REQ for prod] [SECRET] Token shared between backend and the Datacaixa
# bridge (PC running the fiscal-printing client).
# Generate with: openssl rand -hex 32
# Then paste the SAME value into bridge/config.ini on the bridge PC.
# Without it, orders never make it from the bot to the fiscal printer.
BRIDGE_TOKEN=

# [OPT] WhatsApp numbers (digits-only E.164) that receive bot alerts for
# escalations, errors, or daily summaries. Comma-separated.
# Example: 5517999998888,5517999997777
ADMIN_PHONES=


# ----------------------------------------------------------------------------
# Frontend (Vite — read at build time)
# ----------------------------------------------------------------------------
# [REQ] Backend API base URL the React app calls. Change to your prod
# domain when deploying: https://planaltopizzasesorvetes.com
VITE_API_URL=http://localhost:8000
